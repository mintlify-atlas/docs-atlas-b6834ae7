  "projectType": "api-service",
  "projectName": "Pagos Hotspot API",
  "projectDescription": "A multi-tenant FastAPI service that processes card payments via Conekta and Mercado Pago, automatically creates MikroTik Hotspot users, and handles auto-reconnection for WiFi captive portals.",
