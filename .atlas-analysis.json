  "keyFeatures": [
    "Multi-tenant architecture with per-company payment gateway configuration",
    "Conekta payment processing for MikroTik Hotspot access",
    "Mercado Pago payment processing with webhook support",
    "Automatic MikroTik Hotspot user creation and credential delivery",
    "Auto-connection via MAC cookie injection (supports random MAC devices)",
    "Dual authentication: JWT session tokens and JWT-based API Keys per router",
    "Automatic rollback on failed payments (removes MikroTik user)",
    "Telegram notifications for payment events",
    "Role-based access control: super_admin, cliente_admin, end-user API Keys",
    "Alembic database migrations with PostgreSQL"
  ],
